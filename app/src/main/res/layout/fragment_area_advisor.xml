<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:background="@drawable/bg_gradient_rounded"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🏘️ AI Tư vấn khu vực"
                android:textColor="@color/white"
                android:textSize="22sp"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Trả lời vài câu, AI sẽ gợi ý khu vực phù hợp nhất với bạn"
                android:textColor="#CCFFFFFF"
                android:textSize="13sp"
                android:layout_marginTop="6dp"/>
        </LinearLayout>

        <!-- Question 1: Trường -->
        <TextView
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="1️⃣ Bạn học trường nào?"
            android:textStyle="bold" android:textColor="@color/text_primary"
            android:textSize="15sp" android:layout_marginBottom="8dp"/>

        <Spinner
            android:id="@+id/sp_school"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/bg_glass_card"
            android:padding="12dp"/>

        <!-- Question 2: Budget -->
        <TextView
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="2️⃣ Ngân sách của bạn?"
            android:textStyle="bold" android:textColor="@color/text_primary"
            android:textSize="15sp" android:layout_marginTop="16dp" android:layout_marginBottom="8dp"/>

        <Spinner
            android:id="@+id/sp_budget"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/bg_glass_card"
            android:padding="12dp"/>

        <!-- Question 3: Vehicle -->
        <TextView
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="3️⃣ Bạn có xe máy không?"
            android:textStyle="bold" android:textColor="@color/text_primary"
            android:textSize="15sp" android:layout_marginTop="16dp" android:layout_marginBottom="8dp"/>

        <RadioGroup
            android:id="@+id/rg_vehicle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <RadioButton android:id="@+id/rb_has_bike"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="🏍 Có xe máy" android:checked="true"
                android:textColor="@color/text_primary"/>
            <RadioButton android:id="@+id/rb_no_bike"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="🚌 Không có"
                android:textColor="@color/text_primary"/>
        </RadioGroup>

        <!-- Question 4: Room type -->
        <TextView
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="4️⃣ Bạn muốn ở một mình hay ghép?"
            android:textStyle="bold" android:textColor="@color/text_primary"
            android:textSize="15sp" android:layout_marginTop="16dp" android:layout_marginBottom="8dp"/>

        <RadioGroup
            android:id="@+id/rg_room_type"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <RadioButton android:id="@+id/rb_solo"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="🧑 Ở 1 mình" android:checked="true"
                android:textColor="@color/text_primary"/>
            <RadioButton android:id="@+id/rb_share"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="👥 Ghép"
                android:textColor="@color/text_primary"/>
        </RadioGroup>

        <!-- Question 5: Priority -->
        <TextView
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="5️⃣ Ưu tiên của bạn?"
            android:textStyle="bold" android:textColor="@color/text_primary"
            android:textSize="15sp" android:layout_marginTop="16dp" android:layout_marginBottom="8dp"/>

        <RadioGroup
            android:id="@+id/rg_priority"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <RadioButton android:id="@+id/rb_near"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="📍 Gần trường" android:checked="true"
                android:textColor="@color/text_primary"/>
            <RadioButton android:id="@+id/rb_cheap"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="💸 Giá rẻ"
                android:textColor="@color/text_primary"/>
            <RadioButton android:id="@+id/rb_amenity"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="🏪 Gần chợ/BX"
                android:textColor="@color/text_primary"/>
        </RadioGroup>

        <!-- Submit -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_submit"
            style="@style/UniRent.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="🤖 AI phân tích và gợi ý khu vực"
            android:textSize="15sp"/>

        <!-- Loading -->
        <ProgressBar
            android:id="@+id/progress"
            android:layout_width="match_parent"
            android:layout_height="4dp"
            style="?android:attr/progressBarStyleHorizontal"
            android:indeterminate="true"
            android:visibility="gone"
            android:layout_marginTop="8dp"
            android:indeterminateTint="@color/brand"/>

        <!-- Result -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_result"
            style="@style/UniRent.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tv_result"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:lineSpacingExtra="4dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_find"
                    style="@style/UniRent.Button.Primary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="🔍 Tìm phòng trong khu vực này"
                    android:textSize="14sp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
