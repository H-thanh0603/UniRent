<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="16dp"
        android:background="@color/surface" android:elevation="2dp">

        <EditText
            android:id="@+id/et_query"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:padding="14dp"
            android:background="@drawable/bg_search_box"
            android:hint="VD: Tôi học UTE, ngân sách 3 triệu, có máy lạnh, dưới 15ph"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint"
            android:imeOptions="actionSearch"
            android:inputType="text"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_ai_filter"
            style="@style/UniRent.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="🤖 AI tìm giúp tôi"
            android:textSize="14sp"/>

        <HorizontalScrollView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginTop="12dp" android:scrollbars="none">
            <LinearLayout
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView android:id="@+id/chip_under_2m"
                    style="@style/QuickChip" android:text="&lt; 2 triệu"/>
                <TextView android:id="@+id/chip_2_3m"
                    style="@style/QuickChip" android:text="2-3 triệu"/>
                <TextView android:id="@+id/chip_above_3m"
                    style="@style/QuickChip" android:text="≥ 3 triệu"/>
                <TextView android:id="@+id/chip_near_2km"
                    style="@style/QuickChip" android:text="&lt; 2 km"/>
                <TextView android:id="@+id/chip_near_5km"
                    style="@style/QuickChip" android:text="&lt; 5 km"/>
                <TextView android:id="@+id/chip_clear"
                    style="@style/QuickChip" android:text="✕ Bỏ lọc"/>
            </LinearLayout>
        </HorizontalScrollView>
    </LinearLayout>

    <TextView
        android:id="@+id/tv_ai_hint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="8dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:textColor="@color/brand"
        android:textSize="13sp"
        android:visibility="visible"/>

    <ProgressBar
        android:id="@+id/progress"
        android:layout_width="match_parent"
        android:layout_height="4dp"
        style="?android:attr/progressBarStyleHorizontal"
        android:indeterminate="true"
        android:visibility="gone"
        android:indeterminateTint="@color/brand"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_results"
        android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingTop="8dp" android:clipToPadding="false"/>
</LinearLayout>
