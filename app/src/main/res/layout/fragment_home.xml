<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="@dimen/spacing_xxl">

        <!-- Hero Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/page_horizontal"
            android:paddingEnd="@dimen/page_horizontal"
            android:paddingTop="@dimen/spacing_xl"
            android:paddingBottom="@dimen/spacing_lg"
            android:background="@color/primary">

            <TextView
                android:id="@+id/tv_hello"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:textSize="26sp"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hôm nay bạn muốn tìm phòng ở đâu?"
                android:textColor="#D0BCFF"
                android:textSize="15sp"
                android:layout_marginTop="6dp"/>

            <!-- Search card overlay -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_search"
                style="@style/UniRent.Card"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="@dimen/spacing_lg">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="8dp">

                    <ImageView
                        android:layout_width="@dimen/icon_md"
                        android:layout_height="@dimen/icon_md"
                        android:src="@drawable/ic_search"
                        app:tint="@color/text_hint"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="10dp"
                        android:text="Tìm phòng, khu vực, trường học..."
                        android:textColor="@color/text_hint"
                        android:textSize="15sp"/>

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:padding="8dp"
                        android:src="@drawable/ic_filter"
                        app:tint="@color/primary"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <!-- AI Chat Button -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="@dimen/page_horizontal"
            android:paddingEnd="@dimen/page_horizontal"
            android:paddingTop="@dimen/spacing_md">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_ai_chat"
                style="@style/UniRent.Button.Outline"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="🤖 Chat với AI"
                android:textSize="13sp"
                app:cornerRadius="20dp"/>

            <View android:layout_width="8dp" android:layout_height="0dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_area_advisor"
                style="@style/UniRent.Button.Outline"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="🏘️ Tư vấn khu vực"
                android:textSize="13sp"
                app:cornerRadius="20dp"/>
        </LinearLayout>

        <!-- AI Suggestion section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="💡 AI gợi ý cho bạn"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:textStyle="bold"
            android:paddingStart="@dimen/page_horizontal"
            android:paddingEnd="@dimen/page_horizontal"
            android:paddingTop="@dimen/spacing_lg"/>

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:paddingTop="8dp">

            <LinearLayout
                android:id="@+id/ll_ai_chips"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="@dimen/page_horizontal"
                android:paddingEnd="@dimen/page_horizontal"/>
        </HorizontalScrollView>

        <!-- Banner warning -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/page_horizontal"
            android:layout_marginEnd="@dimen/page_horizontal"
            android:layout_marginTop="@dimen/spacing_md"
            android:padding="14dp"
            android:background="@drawable/bg_warning_banner"
            android:text="@string/banner_warning"
            android:textColor="@color/warning"
            android:textSize="13sp"/>

        <!-- Phòng mới đăng -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="@dimen/page_horizontal"
            android:paddingEnd="@dimen/page_horizontal"
            android:paddingTop="@dimen/section_gap">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="🆕 Phòng mới đăng"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Xem tất cả"
                android:textColor="@color/primary"
                android:textSize="13sp"/>
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_newest"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:clipToPadding="false"/>

        <!-- Đánh giá cao -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="@dimen/page_horizontal"
            android:paddingEnd="@dimen/page_horizontal"
            android:paddingTop="@dimen/section_gap">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="⭐ Đánh giá cao"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_top"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:clipToPadding="false"/>

        <!-- Giá tốt -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="@dimen/page_horizontal"
            android:paddingEnd="@dimen/page_horizontal"
            android:paddingTop="@dimen/section_gap">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="💸 Giá tốt nhất"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_cheap"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"/>
    </LinearLayout>
</ScrollView>
