<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Display -->
    <style name="TextDisplay" parent="">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">28sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:lineSpacingExtra">4dp</item>
    </style>

    <!-- Heading 1 -->
    <style name="TextH1" parent="">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">22sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- Heading 2 -->
    <style name="TextH2" parent="">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- Body Large -->
    <style name="TextBody" parent="">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">16sp</item>
        <item name="android:lineSpacingExtra">4dp</item>
    </style>

    <!-- Body Medium -->
    <style name="TextBody2" parent="">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">14sp</item>
        <item name="android:lineSpacingExtra">2dp</item>
    </style>

    <!-- Caption -->
    <style name="TextCaption" parent="">
        <item name="android:textColor">@color/text_hint</item>
        <item name="android:textSize">12sp</item>
    </style>

    <!-- Price - Large Bold Primary -->
    <style name="TextPrice" parent="">
        <item name="android:textColor">@color/brand</item>
        <item name="android:textSize">20sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- Overline / Label -->
    <style name="TextLabel" parent="">
        <item name="android:textColor">@color/brand</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.1</item>
        <item name="android:textAllCaps">true</item>
    </style>
</resources>
